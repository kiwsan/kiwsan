---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found - Ekkachai Kiwsanthia" description="The page you are looking for does not exist.">
  <main style="min-height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 2rem;">
    <div>
      <p style="font-size: 5rem; font-weight: 700; color: var(--color-accent); line-height: 1;">404</p>
      <h1 style="font-size: 1.5rem; margin: 1rem 0 0.5rem;">Page not found</h1>
      <p style="color: var(--color-text-muted); margin-bottom: 2rem;">The page you are looking for does not exist.</p>
      <a href="/" style="color: var(--color-accent); font-weight: 500;">← Back to home</a>
    </div>
  </main>
</Layout>

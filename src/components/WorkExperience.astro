---
import { getCollection } from 'astro:content';

const workExperience = (await getCollection('projects'))
  .filter(p => p.data.type === 'work')
  .sort((a, b) => a.data.order - b.data.order);
---

<section id="experience" class="experience">
  <div class="container">
    <span class="section-label">Career</span>
    <h2>Work Experience</h2>
    <div class="timeline">
      <div class="timeline-line" aria-hidden="true"></div>
      {workExperience.map((work, index) => (
        <article class={`timeline-item ${index % 2 === 0 ? 'timeline-left' : 'timeline-right'}`} data-index={index}>
          <div class="timeline-dot" aria-hidden="true">
            <span class="dot-ring"></span>
          </div>
          <div class="timeline-card">
            <div class="card-accent" aria-hidden="true"></div>
            <time class="period" datetime={work.data.period.includes('Present') ? `${work.data.period.split(' - ')[0]}/P${new Date().getFullYear() - parseInt(work.data.period.split(' - ')[0])}Y` : work.data.period}>{work.data.period}</time>
            <h3>{work.data.title}</h3>
            <span class="company">{work.data.company}</span>

            <div class="work-content">
              <div class="section">
                <strong>Challenge</strong>
                <p>{work.data.challenge}</p>
              </div>
              <div class="section">
                <strong>Solution</strong>
                <p>{work.data.solution}</p>
              </div>
            </div>

            <div class="tech-stack">
              {work.data.tech.map((tech) => (
                <span class="tech-tag">{tech}</span>
              ))}
            </div>

            <div class="results">
              <strong>Results</strong>
              <ul>
                {work.data.results.map((result) => (
                  <li>{result}</li>
                ))}
              </ul>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const target = entry.target as HTMLElement;
        const index = target.dataset.index;
        if (index) {
          setTimeout(() => {
            target.classList.add('animate');
          }, parseInt(index) * 200);
        } else {
          target.classList.add('animate');
        }
        observer.unobserve(target);
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('#experience h2, .timeline-item').forEach(el => observer.observe(el));
</script>

<style>
  .experience {
    padding: var(--space-16) 0;
  }

  h2 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-12);
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  h2.animate {
    opacity: 1;
    transform: translateY(0);
  }

  /* ---------- Timeline structure ---------- */
  .timeline {
    position: relative;
    padding: var(--space-4) 0;
  }

  .timeline-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--color-border) 8%,
      var(--color-primary) 50%,
      var(--color-border) 92%,
      transparent
    );
    transform: translateX(-50%);
  }

  /* ---------- Timeline item ---------- */
  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-10);
    opacity: 0;
  }

  .timeline-item:last-child {
    margin-bottom: 0;
  }

  /* Animate in from left */
  .timeline-left {
    transform: translateX(-40px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Animate in from right */
  .timeline-right {
    transform: translateX(40px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .timeline-item.animate {
    opacity: 1;
    transform: translateX(0);
  }

  /* Card placement: left items put card in col 1, right items in col 2 */
  .timeline-left .timeline-card {
    grid-column: 1;
    grid-row: 1;
    text-align: right;
  }

  .timeline-right .timeline-card {
    grid-column: 2;
    grid-row: 1;
  }

  /* ---------- Center dot ---------- */
  .timeline-dot {
    position: absolute;
    left: 50%;
    top: var(--space-6);
    transform: translateX(-50%);
    z-index: 2;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dot-ring {
    width: 14px;
    height: 14px;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    border: 3px solid var(--color-bg);
    box-shadow: 0 0 0 2px var(--color-primary);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.3s ease;
  }

  .timeline-item:hover .dot-ring {
    transform: scale(1.4);
    box-shadow: 0 0 0 3px var(--color-primary), 0 0 16px rgba(0, 40, 142, 0.25);
  }

  /* ---------- Card ---------- */
  .timeline-card {
    position: relative;
    padding: var(--space-6) var(--space-8);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.35s ease,
                border-color 0.35s ease;
  }

  .timeline-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-primary);
    box-shadow: 0 12px 40px -8px rgba(0, 40, 142, 0.12),
                0 4px 12px -2px rgba(0, 0, 0, 0.06);
  }

  /* Top accent bar */
  .card-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .timeline-card:hover .card-accent {
    opacity: 1;
  }

  /* ---------- Card contents ---------- */
  .period {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-primary);
    background: var(--color-primary-fixed);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-3);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  h3 {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-bottom: var(--space-1);
    color: var(--color-text);
    transition: color 0.3s ease;
  }

  .timeline-card:hover h3 {
    color: var(--color-primary);
  }

  .company {
    display: block;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }

  .work-content {
    margin-bottom: var(--space-5);
  }

  .section {
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }

  .section strong {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: block;
    margin-bottom: var(--space-1);
  }

  .section p {
    margin: 0;
    color: var(--color-text);
  }

  /* Left-aligned cards need left-aligned text for tech/results */
  .timeline-left .tech-stack {
    justify-content: flex-end;
  }

  .timeline-left .results {
    text-align: right;
  }

  .timeline-left .results ul {
    padding-left: 0;
    padding-right: var(--space-5);
    list-style-position: inside;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .tech-tag {
    padding: var(--space-1) var(--space-3);
    background: var(--color-secondary-container);
    color: var(--color-on-secondary-container);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tech-tag:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 4px 12px rgba(0, 40, 142, 0.2);
  }

  .results strong {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .results ul {
    margin-top: var(--space-2);
    padding-left: var(--space-5);
  }

  .results li {
    margin-bottom: var(--space-1);
    color: var(--color-text);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .results li:hover {
    color: var(--color-primary);
  }

  /* ---------- Reduced motion ---------- */
  @media (prefers-reduced-motion: reduce) {
    h2.animate,
    .timeline-item.animate {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .timeline-card:hover,
    .tech-tag:hover,
    .timeline-item:hover .dot-ring {
      transform: none;
    }
  }

  /* ---------- Tablet: single-column left-aligned ---------- */
  @media (max-width: 768px) {
    .experience {
      padding: var(--space-12) 0;
    }

    h2 {
      font-size: var(--text-3xl);
      margin-bottom: var(--space-8);
    }

    .timeline-line {
      left: 20px;
    }

    .timeline-item {
      display: block;
      padding-left: 52px;
      margin-bottom: var(--space-8);
    }

    .timeline-left,
    .timeline-right {
      transform: translateX(-30px);
    }

    .timeline-dot {
      left: 20px;
      top: var(--space-6);
    }

    .timeline-left .timeline-card,
    .timeline-right .timeline-card {
      text-align: left;
    }

    .timeline-left .tech-stack {
      justify-content: flex-start;
    }

    .timeline-left .results {
      text-align: left;
    }

    .timeline-left .results ul {
      padding-left: var(--space-5);
      padding-right: 0;
      list-style-position: outside;
    }

    .timeline-card {
      padding: var(--space-5) var(--space-6);
    }
  }

  /* ---------- Mobile ---------- */
  @media (max-width: 480px) {
    .experience {
      padding: var(--space-8) 0;
    }

    h2 {
      font-size: var(--text-2xl);
    }

    .timeline-line {
      left: 14px;
    }

    .timeline-item {
      padding-left: 40px;
      margin-bottom: var(--space-6);
    }

    .timeline-dot {
      left: 14px;
    }

    .dot-ring {
      width: 12px;
      height: 12px;
    }

    .timeline-card {
      padding: var(--space-4);
    }

    h3 {
      font-size: var(--text-xl);
    }

    .meta {
      flex-direction: column;
      gap: var(--space-1);
    }

    .tech-stack {
      gap: var(--space-2);
    }

    .tech-tag {
      font-size: 0.7rem;
      padding: var(--space-1) var(--space-2);
    }

    .results ul {
      padding-left: var(--space-4);
      font-size: var(--text-sm);
    }
  }
</style>

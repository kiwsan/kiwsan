---
import { getCollection } from 'astro:content';

const workExperience = (await getCollection('projects'))
  .filter(p => p.data.type === 'work')
  .sort((a, b) => a.data.order - b.data.order);
---

<section id="experience" class="experience">
  <div class="container">
    <h2>Work Experience</h2>
    <div class="timeline">
      {workExperience.map((work, index) => (
        <article class="work-card" data-index={index}>
          <div class="work-header">
            <h3>{work.data.title}</h3>
            <div class="meta">
              <span class="company">{work.data.company}</span>
              <span class="period">{work.data.period}</span>
            </div>
          </div>
          
          <div class="work-content">
            <div class="section">
              <strong>Challenge:</strong> {work.data.challenge}
            </div>
            <div class="section">
              <strong>Solution:</strong> {work.data.solution}
            </div>
          </div>

          <div class="tech-stack">
            {work.data.tech.map((tech) => (
              <span class="tech-tag">{tech}</span>
            ))}
          </div>

          <div class="results">
            <strong>Results:</strong>
            <ul>
              {work.data.results.map((result) => (
                <li>{result}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const target = entry.target as HTMLElement;
        const index = target.dataset.index;
        if (index) {
          setTimeout(() => {
            target.classList.add('animate');
          }, parseInt(index) * 150);
        } else {
          target.classList.add('animate');
        }
        observer.unobserve(target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('#experience h2, .work-card').forEach(el => observer.observe(el));
</script>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideInRight {
    from {
      opacity: 0;
      transform: translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  .experience {
    padding: var(--space-16) 0;
  }

  h2 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-8);
    opacity: 0;
  }

  h2.animate {
    animation: fadeInUp 0.6s ease-out forwards;
  }

  .timeline {
    display: grid;
    gap: var(--space-8);
  }

  .work-card {
    padding: var(--space-8) 0;
    border-bottom: 2px solid var(--color-border);
    opacity: 0;
    transform: translateX(30px);
    transition: transform 0.3s ease;
  }

  .work-card.animate {
    animation: slideInRight 0.6s ease-out forwards;
  }

  .work-card:hover {
    transform: translateX(-8px);
  }

  .work-header h3 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-2);
    transition: color 0.3s ease;
  }

  .work-card:hover .work-header h3 {
    color: var(--color-primary);
  }

  .meta {
    display: flex;
    gap: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }

  .company {
    font-weight: 500;
  }

  .work-content {
    margin-bottom: var(--space-5);
  }

  .section {
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }

  .section strong {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: var(--space-1);
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .tech-tag {
    padding: var(--space-2) var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tech-tag:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 4px 12px rgba(255, 92, 122, 0.3);
  }

  .results strong {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .results ul {
    margin-top: var(--space-2);
    padding-left: var(--space-5);
  }

  .results li {
    margin-bottom: var(--space-1);
    color: var(--color-text);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .results li::before {
    content: '';
    position: absolute;
    left: -20px;
    top: 50%;
    transform: translateY(-50%) scaleX(0);
    width: 12px;
    height: 2px;
    background: var(--color-primary);
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .results li:hover {
    transform: translateX(6px);
    color: var(--color-primary);
  }

  .results li:hover::before {
    transform: translateY(-50%) scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    h2.animate,
    .work-card.animate {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .work-card:hover,
    .tech-tag:hover,
    .results li:hover {
      transform: none;
    }
  }

  @media (max-width: 768px) {
    .experience {
      padding: var(--space-12) 0;
    }
    h2 {
      font-size: var(--text-3xl);
    }
    .work-card {
      padding: var(--space-5) 0;
    }
  }

  @media (max-width: 480px) {
    .experience {
      padding: var(--space-8) 0;
    }
    h2 {
      font-size: var(--text-2xl);
    }
    .work-card {
      padding: var(--space-4) 0;
    }
    .work-header h3 {
      font-size: var(--text-xl);
    }
    .meta {
      flex-direction: column;
      gap: var(--space-1);
    }
    .tech-stack {
      gap: var(--space-1);
    }
    .tech-tag {
      font-size: 0.65rem;
      padding: var(--space-1) var(--space-2);
    }
    .results ul {
      padding-left: var(--space-4);
      font-size: var(--text-sm);
    }
  }
</style>

---
---

<header class="header">
  <!-- Background -->
  <div class="header-bg"></div>
  
  <div class="container">
    <a href="/" class="logo" aria-label="Home">
      <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="logo-svg" role="img" aria-hidden="true">

        <!-- flow lines -->
        <path d="M5 28C13 6 27 6 35 28"
              stroke="#191c1e"
              stroke-width="3"
              fill="none"
              stroke-linecap="round"/>

        <path d="M5 12C13 34 27 34 35 12"
              stroke="#191c1e"
              stroke-width="3"
              fill="none"
              stroke-linecap="round"/>

        <!-- endpoints -->
        <circle cx="5" cy="28" r="1.2" fill="#191c1e"/>
        <circle cx="35" cy="28" r="1.2" fill="#191c1e"/>
        <circle cx="5" cy="12" r="1.2" fill="#191c1e"/>
        <circle cx="35" cy="12" r="1.2" fill="#191c1e"/>

      </svg>
    </a>
    <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav class="nav" id="nav">
      <a href="#experience">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
          <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
        </svg>
        Experience
      </a>
      <a href="#projects">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
        </svg>
        Projects
      </a>
      <a href="#contact">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        Contact
      </a>
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .header-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: rgba(255, 255, 255, 0.8);
    transition: background-color 0.3s ease;
  }

  .header .container {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-4);
    padding-bottom: var(--space-4);
  }

  .logo {
    display: inline-flex;
    align-items: center;
  }

  .logo-svg {
    display: block;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  [data-theme="dark"] .header-bg {
    background: rgba(26, 27, 38, 0.8);
  }

  [data-theme="dark"] .logo-svg path {
    stroke: #ffffff;
  }

  [data-theme="dark"] .logo-svg circle {
    fill: #ffffff;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .header-bg {
      background: rgba(26, 27, 38, 0.8);
    }
    :root:not([data-theme="light"]) .logo-svg path {
      stroke: #ffffff;
    }
    :root:not([data-theme="light"]) .logo-svg circle {
      fill: #ffffff;
    }
  }

  .logo:hover .logo-svg {
    opacity: 0.8;
    transform: scale(1.05);
  }

  @media (max-width: 480px) {
    .logo-svg {
      width: 32px;
      height: 32px;
    }
  }

  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .nav a {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .nav a svg {
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .nav a:hover svg {
    transform: translateY(-2px);
  }

  .nav a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .nav {
      gap: var(--space-4);
    }
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .menu-toggle span {
    width: 24px;
    height: 2px;
    background: var(--color-text);
    transition: all 0.3s;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(6px, -6px);
  }

  @media (max-width: 768px) {
    .menu-toggle {
      display: flex;
      z-index: 60;
    }

    .nav {
      position: fixed;
      top: 60px;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: var(--color-bg);
      padding: var(--space-4) var(--space-5);
      gap: var(--space-1);
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition: max-height 0.35s ease, opacity 0.25s ease;
      box-shadow: 0 8px 32px rgba(25, 28, 30, 0.08);
      border-top: 1px solid var(--color-border);
    }

    .nav.active {
      max-height: 400px;
      opacity: 1;
    }

    .nav a {
      font-size: var(--text-base);
      font-weight: 500;
      padding: var(--space-3) var(--space-4);
      border-radius: var(--radius-md);
      transition: all 0.2s ease;
    }

    .nav a:hover {
      background: var(--color-surface);
    }

    .theme-toggle {
      margin-top: var(--space-3);
      align-self: center;
    }
  }

  @media (max-width: 480px) {
    .header .container {
      padding-top: var(--space-3);
      padding-bottom: var(--space-3);
    }
  }
</style>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('nav');

  menuToggle?.addEventListener('click', () => {
    menuToggle.classList.toggle('active');
    nav?.classList.toggle('active');
  });

  nav?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menuToggle?.classList.remove('active');
      nav?.classList.remove('active');
    });
  });
</script>

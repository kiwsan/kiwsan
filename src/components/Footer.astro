---
const buildVersion = import.meta.env.PUBLIC_BUILD_VERSION || 'dev';
---

<footer class="footer">
  <div class="container">
    <div class="footer-referrals">
      <p>Deploy your next app in seconds. Get $100 in cloud credits:</p>
      <a href="https://www.digitalocean.com/?refcode=0e2c3672d1dc&utm_campaign=Referral_Invite&utm_medium=Referral_Program&utm_source=badge" target="_blank" rel="noopener noreferrer">
        <img src="/images/digitalocean-badge.svg" alt="DigitalOcean Referral Badge - Get $100 Cloud Credits" width="120" height="36" loading="lazy" decoding="async" />
      </a>
      <p>Premium web hosting with 20% off:</p>
      <a href="https://www.hostinger.com/th?REFERRALCODE=GWYKIWSANQZC" target="_blank" rel="noopener noreferrer">
        <img src="/images/hostinger-black.svg" alt="Hostinger Referral Badge - Premium Web Hosting 20% Off" width="120" height="36" loading="lazy" decoding="async" />
      </a>
    </div>
    <div class="footer-content">
      <p>&copy; {new Date().getFullYear()} Ekkachai Kiwsanthia. All rights reserved.</p>
      <p class="build-version">build version: {buildVersion}</p>
      <div class="footer-links">
        <a href="https://github.com/kiwsan" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://www.linkedin.com/in/kiwsan" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="mailto:kiwsanthia@gmail.com">Email</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-8) 0;
    background: #1c1e20;
    color: #ffffff;
    margin-top: 0;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }

  .footer-content p {
    font-size: var(--text-sm);
    color: #cbd2dd;
  }

  .build-version {
    font-size: var(--text-xs) !important;
    color: #cbd2dd;
  }

  .footer-links {
    display: flex;
    gap: var(--space-6);
  }

  .footer-links a {
    font-size: var(--text-sm);
    color: #cbd2dd;
    transition: color 0.3s ease;
  }

  .footer-links a:hover {
    color: #ffffff;
  }

  .footer-referrals {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-6);
  }

  .footer-referrals p {
    font-size: var(--text-xs);
    color: #cbd2dd;
    width: 100%;
    margin: 0;
  }

  .footer-referrals p:not(:first-child) {
    margin-top: var(--space-2);
  }

  .footer-referrals img {
    height: 36px;
  }

  @media (max-width: 768px) {
    .footer-content {
      flex-direction: column;
      text-align: center;
      gap: var(--space-3);
    }
    .footer-referrals {
      justify-content: center;
      text-align: center;
    }
    .footer-links {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .footer {
      padding: var(--space-6) 0;
    }
    .footer-links {
      gap: var(--space-4);
    }
    .footer-referrals img {
      height: 30px;
    }
  }
</style>

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <p>&copy; {new Date().getFullYear()} Ekkachai Kiwsanthia. All rights reserved.</p>
      <div class="footer-links">
        <a href="https://github.com/kiwsan" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://www.linkedin.com/in/kiwsan" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="mailto:kiwsanthia@gmail.com">Email</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
    margin-top: var(--space-16);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }

  .footer-content p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .footer-links {
    display: flex;
    gap: var(--space-6);
  }

  .footer-links a {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 480px) {
    .footer {
      padding: var(--space-6) 0;
      margin-top: var(--space-8);
    }
    .footer-content {
      flex-direction: column;
      text-align: center;
      gap: var(--space-3);
    }
    .footer-links {
      gap: var(--space-4);
    }
  }
</style>

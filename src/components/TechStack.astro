---
import skills from '../data/skills.json';
---

<section class="tech-stack">
  <div class="container">
    <h2>Tech Stack</h2>
    
    <div class="skills-section">
      <h3>Expert</h3>
      <div class="skills-grid">
        {skills.expert.map((skill) => (
          <span class="skill-tag expert">{skill}</span>
        ))}
      </div>
    </div>

    <div class="skills-section">
      <h3>Proficient</h3>
      <div class="skills-grid">
        {skills.proficient.map((skill) => (
          <span class="skill-tag proficient">{skill}</span>
        ))}
      </div>
    </div>

    <div class="skills-section">
      <h3>Specialized</h3>
      <div class="skills-grid">
        {skills.specialized.map((skill) => (
          <span class="skill-tag specialized">{skill}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .tech-stack {
    padding: var(--space-16) 0;
    background: var(--color-surface);
  }

  h2 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-8);
  }

  .skills-section {
    margin-bottom: var(--space-8);
  }

  .skills-section:last-child {
    margin-bottom: 0;
  }

  h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
    font-weight: 500;
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .skill-tag {
    padding: var(--space-2) var(--space-3);
    border-radius: 9999px;
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    font-weight: 500;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: default;
  }

  .skill-tag:hover {
    transform: translateY(-2px) scale(1.05);
  }

  .skill-tag.expert {
    background: var(--color-text);
    color: var(--color-bg);
  }

  .skill-tag.proficient {
    background: var(--color-accent);
    color: white;
  }

  .skill-tag.specialized {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .tech-stack {
      padding: var(--space-12) 0;
    }
    h2 {
      font-size: var(--text-3xl);
    }
  }
</style>

---
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter(p => p.data.type === 'personal')
  .sort((a, b) => a.data.order - b.data.order);
---

<section id="projects" class="projects">
  <div class="container">
    <h2>Featured Projects</h2>
    <div class="projects-grid">
      {projects.map((project) => (
        <article class="project-card fade-in-item">
          <div class="project-header">
            <h3>{project.data.title}</h3>
            <div class="meta">
              <span class="company">{project.data.company}</span>
              <span class="period">{project.data.period}</span>
            </div>
          </div>
          
          <div class="project-content">
            <div class="section">
              <strong>Challenge:</strong> {project.data.challenge}
            </div>
            <div class="section">
              <strong>Solution:</strong> {project.data.solution}
            </div>
          </div>

          <div class="tech-stack">
            {project.data.tech.map((tech) => (
              <span class="tech-tag">{tech}</span>
            ))}
          </div>

          <div class="results">
            <strong>Results:</strong>
            <ul>
              {project.data.results.map((result) => (
                <li>{result}</li>
              ))}
            </ul>
          </div>

          {project.data.link && (
            <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="project-link" aria-label={`Visit ${project.data.title} (opens in new tab)`}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              Visit Project
            </a>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    padding: var(--space-16) 0;
    background: var(--color-surface);
  }

  h2 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-8);
  }

  .projects-grid {
    display: grid;
    gap: var(--space-8);
  }

  .project-card {
    padding: var(--space-8) 0;
    border-bottom: 2px solid var(--color-border);
  }

  .project-header h3 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-2);
  }

  .meta {
    display: flex;
    gap: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }

  .company {
    font-weight: 500;
  }

  .project-content {
    margin-bottom: var(--space-5);
  }

  .section {
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }

  .section strong {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: var(--space-1);
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .tech-tag {
    padding: var(--space-1) var(--space-2);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 500;
    font-family: var(--font-mono);
  }

  .results strong {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .results ul {
    margin-top: var(--space-2);
    padding-left: var(--space-5);
  }

  .results li {
    margin-bottom: var(--space-1);
    color: var(--color-text);
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-5);
    padding: var(--space-2) var(--space-4);
    background: var(--color-primary);
    color: white;
    border: 1px solid var(--color-primary);
    border-radius: 9999px;
    font-weight: 600;
    font-size: var(--text-xs);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project-link:hover {
    background: var(--color-secondary);
    border-color: var(--color-secondary);
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(255, 92, 122, 0.25);
  }

  .project-link svg {
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .project-link:hover svg {
    transform: translateX(2px);
  }

  @media (max-width: 768px) {
    .projects {
      padding: var(--space-12) 0;
    }
    h2 {
      font-size: var(--text-3xl);
    }
    .project-card {
      padding: var(--space-5);
    }
  }
</style>

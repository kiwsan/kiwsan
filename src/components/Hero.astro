---
---

<section class="hero">
  <!-- Background -->
  <div class="hero-bg" aria-hidden="true">
    <!-- Diagonal field -->
    <div class="hero-bg-field"></div>

    <!-- Curved SVG shapes -->
    <svg class="hero-bg-shapes" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMaxYMid slice">
      <!-- Large soft arc -->
      <path d="M 800 0 Q 560 80 620 300 Q 680 520 800 600 Z" fill="url(#grad1)" opacity="0.55"/>
      <!-- Medium inner curve -->
      <path d="M 800 120 Q 620 200 660 380 Q 700 500 800 560 Z" fill="url(#grad2)" opacity="0.4"/>
      <!-- Small floating orb -->
      <ellipse cx="620" cy="160" rx="90" ry="90" fill="url(#grad3)" opacity="0.22"/>
      <!-- Subtle ring -->
      <circle cx="700" cy="420" r="120" fill="none" stroke="url(#strokeGrad)" stroke-width="1.5" opacity="0.35"/>
      <!-- Tiny accent dot -->
      <circle cx="530" cy="80" r="14" fill="#00288e" opacity="0.12"/>
      <circle cx="760" cy="280" r="8" fill="#00288e" opacity="0.16"/>

      <defs>
        <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#dde1ff"/>
          <stop offset="100%" stop-color="#e8eefb"/>
        </linearGradient>
        <linearGradient id="grad2" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#d0e1fb"/>
          <stop offset="100%" stop-color="#f2f4f6"/>
        </linearGradient>
        <radialGradient id="grad3" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#8ba5e6"/>
          <stop offset="100%" stop-color="#dde1ff" stop-opacity="0"/>
        </radialGradient>
        <linearGradient id="strokeGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#00288e"/>
          <stop offset="100%" stop-color="#003272"/>
        </linearGradient>
      </defs>
    </svg>

    <!-- Subtle grid overlay on white side -->
    <div class="hero-bg-grid"></div>
  </div>
  
  <div class="container">
    <div class="hero-content">
      <div class="hero-text">
        <p class="greeting animate-fade-in-up stagger-1">Hi, I'm Ekkachai K.</p>
        <h1 class="animate-fade-in-up stagger-2">Full Stack Software Engineer — I build systems that process<br /><span class="highlight">Million+ orders/year</span></h1>
        <p class="hero-description animate-fade-in-up stagger-2-5">Based in Bangkok, Thailand with 10+ years experience building scalable e-commerce systems for companies like Shopee and Lazada. Specialized in React, TypeScript, Node.js, and AWS cloud architecture delivering high-performance solutions that handle millions of transactions.</p>
        <div class="tags animate-fade-in-up stagger-3">
          <span>Technical Lead</span>
          <span>Full Stack • Software Engineer</span>
          <span>React • TypeScript • AWS</span>
          <span>Cloud Architecture</span>
          <span>Bangkok</span>
        </div>
        <div class="cta animate-fade-in-up stagger-4">
          <a href="#experience" class="btn-primary">View My Work</a>
        </div>
      </div>
      
      <div class="hero-illustration animate-fade-in-up stagger-5">
        <img src="/hero-illustration.svg" alt="Full Stack Software Engineer - Ekkachai K. Portfolio Illustration" width="350" height="350" loading="eager" fetchpriority="high" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: var(--space-4) 0;
    overflow: hidden;
    min-height: calc(100vh - 60px);
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    transition: background-color 0.3s ease;
  }

  /* Diagonal split: crisp white-gray left → soft blue right */
  .hero-bg-field {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        112deg,
        #f7f9fb 0%,
        #f7f9fb 52%,
        #e8eefb 52%,
        #dde1ff 100%
      );
  }

  /* SVG curved shapes pinned to the right */
  .hero-bg-shapes {
    position: absolute;
    top: 0;
    right: 0;
    width: 55%;
    height: 100%;
    pointer-events: none;
  }

  /* Subtle dot-grid on the left (white) half only */
  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0,40,142,0.07) 1px, transparent 1px);
    background-size: 28px 28px;
    /* clip to left half only */
    clip-path: polygon(0 0, 52% 0, 42% 100%, 0 100%);
  }

  /* ── Dark mode overrides ── */
  [data-theme="dark"] .hero-bg-field {
    background:
      linear-gradient(
        112deg,
        #1a1b26 0%,
        #1a1b26 52%,
        #1e2540 52%,
        #1c2b4a 100%
      );
  }

  [data-theme="dark"] .hero-bg-grid {
    background-image: radial-gradient(circle, rgba(122,162,247,0.08) 1px, transparent 1px);
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .hero-bg-field {
      background:
        linear-gradient(
          112deg,
          #1a1b26 0%,
          #1a1b26 52%,
          #1e2540 52%,
          #1c2b4a 100%
        );
    }
    :root:not([data-theme="light"]) .hero-bg-grid {
      background-image: radial-gradient(circle, rgba(122,162,247,0.08) 1px, transparent 1px);
    }
  }

  .hero .container {
    position: relative;
  }

  .hero-content {
    display: flex;
    align-items: center;
    gap: var(--space-12);
    width: 100%;
  }

  .hero-text {
    flex: 2;
  }

  .hero-illustration {
    flex: 1;
  }

  .hero-text {
    max-width: 100%;
  }

  .hero-illustration {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-illustration img {
    width: 100%;
    height: auto;
    max-width: 350px;
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-6);
    max-width: 600px;
  }

  .greeting {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  h1 {
    font-size: var(--text-5xl);
    font-weight: bold;
    margin-bottom: var(--space-6);
    letter-spacing: -0.02em;
  }

  .highlight {
    color: var(--color-accent);
    display: inline-block;
    cursor: pointer;
  }

  .highlight:hover {
    animation: softBounce 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
    color: var(--color-primary);
  }

  @keyframes softBounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  .tags {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }

  .tags span {
    padding: var(--space-1) var(--space-3);
    background: #d0e1fb;
    color: #54647a;
    border-radius: 9999px;
    font-size: var(--text-xs);
    font-weight: 500;
  }

  .cta {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .btn-primary, .btn-secondary {
    padding: var(--space-3) var(--space-6);
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    font-size: var(--text-sm);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .btn-primary {
    background: linear-gradient(135deg, #00288e, #1e40af);
    color: white;
    border: none;
    animation: pulse 2s ease-in-out infinite;
    animation-play-state: var(--pulse-play, running);
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, #003272, #00288e);
    text-decoration: none;
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 10px 25px rgba(0, 40, 142, 0.25);
    animation: none;
  }

  @keyframes pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(0, 40, 142, 0.4);
    }
    50% {
      box-shadow: 0 0 0 8px rgba(0, 40, 142, 0);
    }
  }

  .btn-secondary {
    border: none;
    color: #00288e;
    background: #dde1ff;
  }

  .btn-secondary:hover {
    background: #d0e1fb;
    text-decoration: none;
    transform: scale(1.01);
    box-shadow: 0 4px 12px rgba(0, 40, 142, 0.08);
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: var(--space-8) 0;
    }
    .hero-content {
      flex-direction: column;
      gap: var(--space-6);
      text-align: center;
    }
    .hero-illustration {
      order: -1;
      max-width: 300px;
      margin: 0 auto;
    }
    .hero-illustration img {
      max-width: 100%;
    }
    h1 {
      font-size: var(--text-3xl);
    }
    .tags {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: var(--space-6) 0;
      min-height: calc(100vh - 52px);
    }
    .hero-illustration {
      max-width: 250px;
    }
    h1 {
      font-size: var(--text-2xl);
      line-height: 1.3;
    }
    h1 br {
      display: none;
    }
    .greeting {
      font-size: var(--text-sm);
    }
    .tags {
      gap: var(--space-2);
    }
    .tags span {
      font-size: 0.7rem;
      padding: var(--space-1) var(--space-2);
    }
    .cta a {
      width: 100%;
      padding: var(--space-3) var(--space-4);
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
  }

  .stagger-1 { animation-delay: 0.1s; }
  .stagger-2 { animation-delay: 0.2s; }
  .stagger-2-5 { animation-delay: 0.25s; }
  .stagger-3 { animation-delay: 0.3s; }
  .stagger-4 { animation-delay: 0.4s; }
  .stagger-5 { animation-delay: 0.5s; }

  .hero-illustration img {
    animation: float 6s ease-in-out infinite;
  }

  @media (max-width: 768px) {
    .hero-illustration img {
      animation: none;
    }
  }

  .tags span {
    transition: all 0.3s ease;
  }

  .tags span:hover {
    transform: translateY(-2px);
    background: #00288e;
    color: white;
  }
</style>

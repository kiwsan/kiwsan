---
---

<section class="hero">
  <!-- Background -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-bg-field"></div>
    <svg class="hero-bg-shapes" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMaxYMid slice">
      <path d="M 800 0 Q 560 80 620 300 Q 680 520 800 600 Z" fill="url(#grad1)" opacity="0.55"/>
      <path d="M 800 120 Q 620 200 660 380 Q 700 500 800 560 Z" fill="url(#grad2)" opacity="0.4"/>
      <ellipse cx="620" cy="160" rx="90" ry="90" fill="url(#grad3)" opacity="0.22"/>
      <circle cx="700" cy="420" r="120" fill="none" stroke="url(#strokeGrad)" stroke-width="1.5" opacity="0.35"/>
      <circle cx="530" cy="80" r="14" fill="#00288e" opacity="0.12"/>
      <circle cx="760" cy="280" r="8" fill="#00288e" opacity="0.16"/>
      <defs>
        <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#dde1ff"/>
          <stop offset="100%" stop-color="#e8eefb"/>
        </linearGradient>
        <linearGradient id="grad2" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#d0e1fb"/>
          <stop offset="100%" stop-color="#f2f4f6"/>
        </linearGradient>
        <radialGradient id="grad3" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#8ba5e6"/>
          <stop offset="100%" stop-color="#dde1ff" stop-opacity="0"/>
        </radialGradient>
        <linearGradient id="strokeGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#00288e"/>
          <stop offset="100%" stop-color="#003272"/>
        </linearGradient>
      </defs>
    </svg>
    <div class="hero-bg-grid"></div>
  </div>

  <div class="container">
    <div class="hero-content">
      <div class="hero-text">
        <span class="hero-label animate-fade-in-up stagger-1">Software Engineer &mdash; Bangkok, Thailand</span>
        <h1 class="animate-fade-in-up stagger-2">
          I build systems<br />that process<br />
          <span class="highlight">Million+ orders</span>
        </h1>
        <div class="hero-rule animate-fade-in-up stagger-2-5"></div>
        <p class="hero-description animate-fade-in-up stagger-3">Full Stack Engineer with 10+ years crafting scalable e-commerce systems for Shopee, Lazada, and MC Group. Specialized in React, TypeScript, Node.js, and AWS cloud architecture.</p>
        <div class="tags animate-fade-in-up stagger-4">
          <span>Technical Lead</span>
          <span>Full Stack</span>
          <span>React &bull; TypeScript &bull; AWS</span>
          <span>Cloud Architecture</span>
        </div>
        <div class="cta animate-fade-in-up stagger-5">
          <a href="#experience" class="btn-primary">View My Work</a>
          <a href="#contact" class="btn-secondary">Get in Touch</a>
        </div>
      </div>

      <div class="hero-illustration animate-fade-in-up stagger-5">
        <img src="/hero-illustration.svg" alt="Full Stack Software Engineer - Ekkachai K. Portfolio Illustration" width="350" height="350" loading="eager" fetchpriority="high" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: var(--space-8) 0;
    overflow: hidden;
    min-height: calc(100vh - 60px);
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    transition: background-color 0.3s ease;
  }

  .hero-bg-field {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        112deg,
        #f7f9fb 0%,
        #f7f9fb 52%,
        #e8eefb 52%,
        #dde1ff 100%
      );
  }

  .hero-bg-shapes {
    position: absolute;
    top: 0;
    right: 0;
    width: 55%;
    height: 100%;
    pointer-events: none;
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0,40,142,0.07) 1px, transparent 1px);
    background-size: 28px 28px;
    clip-path: polygon(0 0, 52% 0, 42% 100%, 0 100%);
  }

  /* Dark mode */
  [data-theme="dark"] .hero-bg-field {
    background:
      linear-gradient(112deg, #1a1b26 0%, #1a1b26 52%, #1e2540 52%, #1c2b4a 100%);
  }

  [data-theme="dark"] .hero-bg-grid {
    background-image: radial-gradient(circle, rgba(122,162,247,0.08) 1px, transparent 1px);
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .hero-bg-field {
      background:
        linear-gradient(112deg, #1a1b26 0%, #1a1b26 52%, #1e2540 52%, #1c2b4a 100%);
    }
    :root:not([data-theme="light"]) .hero-bg-grid {
      background-image: radial-gradient(circle, rgba(122,162,247,0.08) 1px, transparent 1px);
    }
  }

  .hero .container {
    position: relative;
  }

  .hero-content {
    display: flex;
    align-items: center;
    gap: var(--space-16);
    width: 100%;
  }

  .hero-text {
    flex: 2;
    max-width: 100%;
  }

  .hero-illustration {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-illustration img {
    width: 100%;
    height: auto;
    max-width: 380px;
  }

  /* Editorial label */
  .hero-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
    display: block;
  }

  /* Display heading — extreme scale */
  h1 {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-6);
    color: var(--color-text);
  }

  .highlight {
    color: var(--color-primary);
    display: inline-block;
    cursor: pointer;
    position: relative;
  }

  .highlight::after {
    content: '';
    position: absolute;
    bottom: 0.06em;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, #00288e, #1e40af);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .highlight:hover::after {
    transform: scaleX(1);
  }

  .highlight:hover {
    color: var(--color-primary-container);
  }

  /* Accent rule — editorial divider */
  .hero-rule {
    width: 48px;
    height: 3px;
    background: linear-gradient(90deg, #00288e, #1e40af);
    border-radius: 2px;
    margin-bottom: var(--space-6);
  }

  .hero-description {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-8);
    max-width: 540px;
  }

  .tags {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-10);
    flex-wrap: wrap;
  }

  .tags span {
    padding: var(--space-1) var(--space-3);
    background: var(--color-secondary-container);
    color: var(--color-on-secondary-container);
    border-radius: 9999px;
    font-size: var(--text-xs);
    font-weight: 500;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .tags span:hover {
    transform: translateY(-2px);
    background: var(--color-primary);
    color: white;
    box-shadow: 0 4px 12px rgba(0, 40, 142, 0.18);
  }

  .cta {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .btn-primary, .btn-secondary {
    padding: 0.875rem var(--space-8);
    border-radius: 8px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: 0.01em;
    transition: all 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .btn-primary {
    background: linear-gradient(135deg, #00288e, #1e40af);
    color: white;
    border: none;
    box-shadow: 0 2px 8px rgba(0, 40, 142, 0.18);
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, #003272, #00288e);
    text-decoration: none;
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(0, 40, 142, 0.22);
    color: white;
  }

  .btn-secondary {
    border: none;
    color: var(--color-primary);
    background: var(--color-primary-fixed);
  }

  .btn-secondary:hover {
    background: var(--color-secondary-container);
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0, 40, 142, 0.08);
    color: var(--color-primary);
  }

  /* Animations */
  .animate-fade-in-up {
    animation: fadeInUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    opacity: 0;
  }

  .stagger-1 { animation-delay: 0.1s; }
  .stagger-2 { animation-delay: 0.25s; }
  .stagger-2-5 { animation-delay: 0.35s; }
  .stagger-3 { animation-delay: 0.45s; }
  .stagger-4 { animation-delay: 0.55s; }
  .stagger-5 { animation-delay: 0.7s; }

  .hero-illustration img {
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-16px); }
  }

  /* Responsive — tablet landscape */
  @media (max-width: 1024px) {
    .hero-content {
      gap: var(--space-8);
    }
    .hero-illustration img {
      max-width: 300px;
    }
    h1 {
      font-size: var(--text-display-md);
    }
  }

  /* Responsive — tablet portrait & mobile */
  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: var(--space-8) 0;
    }
    .hero-bg-field {
      background: var(--color-surface) !important;
    }
    .hero-bg-shapes {
      opacity: 0.15;
      width: 100%;
    }
    .hero-bg-grid {
      clip-path: none;
      opacity: 0.5;
    }
    .hero-content {
      flex-direction: column;
      gap: var(--space-6);
      text-align: center;
    }
    .hero-illustration {
      order: -1;
      max-width: 240px;
      margin: 0 auto;
    }
    h1 {
      font-size: var(--text-display-sm);
    }
    h1 br { display: none; }
    .hero-rule {
      margin-left: auto;
      margin-right: auto;
    }
    .hero-description {
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
    }
    .tags {
      justify-content: center;
    }
    .cta {
      justify-content: center;
    }
    .hero-illustration img {
      animation: none;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: var(--space-6) 0;
      min-height: calc(100svh - 52px);
    }
    .hero-illustration {
      max-width: 180px;
    }
    h1 {
      font-size: var(--text-3xl);
      line-height: 1.15;
    }
    .hero-description {
      font-size: var(--text-sm);
    }
    .tags {
      gap: var(--space-2);
    }
    .tags span {
      font-size: 0.75rem;
      padding: var(--space-1) var(--space-3);
    }
    .cta {
      flex-direction: column;
      width: 100%;
    }
    .cta a {
      width: 100%;
      padding: var(--space-3) var(--space-4);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-up { animation: none; opacity: 1; }
    .hero-illustration img { animation: none; }
    .stagger-1, .stagger-2, .stagger-2-5, .stagger-3, .stagger-4, .stagger-5 { opacity: 1; }
  }
</style>

---
import metrics from '../data/metrics.json';
---

<section class="metrics">
  <div class="container">
    <div class="metrics-grid">
      {metrics.map((metric, i) => (
        <div class={`metric-card animate-fade-in-up stagger-${i + 1}`}>
          <div class="value" data-target={metric.value}>{metric.value}</div>
          <div class="label">{metric.label}</div>
          <div class="description">{metric.description}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Only animate simple values: leading digits followed by an optional suffix (e.g. "250K+", "50%")
  // Complex values like "48→24h" are left as-is
  function isAnimatable(target: string): boolean {
    return /^\d+[^\d]*$/.test(target);
  }

  function animateValue(el: HTMLElement, target: string) {
    const num = parseInt(target.replace(/[^0-9]/g, ''), 10);
    const suffix = target.replace(/^\d+/, '');
    const duration = 2000;
    const increment = num / (duration / 16);
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    timer = setInterval(() => {
      current += increment;
      if (current >= num) {
        el.textContent = target;
        clearInterval(timer);
      } else {
        el.textContent = String(Math.floor(current)) + suffix;
      }
    }, 16);
  }

  document.querySelectorAll('.value').forEach((el) => {
    const target = el.getAttribute('data-target');
    if (!target) return;

    if (isAnimatable(target)) {
      const suffix = target.replace(/^\d+/, '');
      el.textContent = '0' + suffix;
      setTimeout(() => animateValue(el as HTMLElement, target), 300);
    }
    // Non-animatable values (e.g. "48→24h") keep their SSR-rendered text
  });
</script>

<style>
  .metrics {
    padding: var(--space-12) 0;
    background: var(--color-surface);
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-8);
  }

  .metric-card {
    text-align: center;
    padding: var(--space-6) var(--space-4);
    transition: transform 0.3s ease;
  }

  .metric-card:hover {
    transform: translateY(-4px);
  }

  .value {
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
    font-variant-numeric: tabular-nums;
  }

  .label {
    font-size: var(--text-base);
    font-weight: 500;
    margin-bottom: var(--space-2);
  }

  .description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }
    .value {
      font-size: var(--text-4xl);
    }
  }
</style>

---
import metrics from '../data/metrics.json';
---

<section class="metrics">
  <div class="container">
    <div class="metrics-grid">
      {metrics.map((metric, i) => (
        <div class={`metric-card animate-fade-in-up stagger-${i + 1}`}>
          <div class="value" data-target={metric.value}>{metric.value}</div>
          <div class="label">{metric.label}</div>
          <div class="description">{metric.description}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function animateValue(el: HTMLElement, target: string) {
    const num = parseInt(target.replace(/[^0-9]/g, ''), 10);
    const suffix = target.replace(/^\d+/, '');
    const duration = 2000;
    const start = performance.now();

    function step(now: number) {
      const progress = Math.min((now - start) / duration, 1);
      el.textContent = String(Math.floor(progress * num)) + suffix;
      if (progress < 1) requestAnimationFrame(step);
      else el.textContent = target;
    }

    requestAnimationFrame(step);
  }

  document.querySelectorAll('.value').forEach((el) => {
    const target = el.getAttribute('data-target');
    if (!target || !/^\d+[^\d]*$/.test(target)) return;
    const suffix = target.replace(/^\d+/, '');
    el.textContent = '0' + suffix;
    setTimeout(() => animateValue(el as HTMLElement, target), 300);
  });
</script>

<style>
  .metrics {
    padding: var(--space-4) 0;
    background: var(--color-surface-container-low);
    min-height: 45vh;
    display: flex;
    align-items: center;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-8);
  }

  .metric-card {
    text-align: center;
    padding: var(--space-6) var(--space-4);
    transition: transform 0.3s ease;
  }

  .metric-card:hover {
    transform: translateY(-4px);
  }

  .value {
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
    font-variant-numeric: tabular-nums;
  }

  .label {
    font-size: var(--text-base);
    font-weight: 500;
    margin-bottom: var(--space-2);
  }

  .description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .metrics {
      min-height: auto;
      padding: var(--space-8) 0;
    }
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
    .metric-card {
      padding: var(--space-4);
    }
    .value {
      font-size: var(--text-3xl);
    }
  }

  @media (max-width: 480px) {
    .metrics {
      padding: var(--space-6) 0;
    }
    .metrics-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .metric-card {
      padding: var(--space-3);
    }
    .value {
      font-size: var(--text-2xl);
    }
    .label {
      font-size: var(--text-sm);
    }
    .description {
      font-size: var(--text-xs);
    }
  }
</style>
